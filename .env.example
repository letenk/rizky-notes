# ===================================
# ENVIRONMENT VARIABLES
# ===================================
# Variables below are read directly by Hugo templates at build time.
# In Netlify: set via Site Settings → Build & Deploy → Environment Variables
# ===================================

# Analytics - Google Analytics 4
# Used by: layouts/partials/analytics.html
# Only active in production build (not during hugo server)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Comments System - Giscus
# Configured directly in hugo.toml under [params.giscus] — not needed here.
# Giscus values (repo ID, category ID) are public identifiers, not secrets.
